@model IEnumerable<Tournament>
@{
    ViewData["Title"] = "Tournaments";
    var authed = User.Identity?.IsAuthenticated == true;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Tournaments</h2>
    @if (authed)
    {
        <a class="btn btn-warning fw-bold" asp-action="Create">+ New Tournament</a>
    }
</div>

@if (!Model.Any())
{
    <div class="alert alert-secondary">No tournaments yet.@(authed ? " Create one to get started." : "")</div>
}

<div class="list-group">
    @foreach (var t in Model)
    {
        <div class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
            <a asp-action="Detail" asp-route-id="@t.Id" class="stretched-link text-decoration-none fw-semibold text-reset">@t.Name</a>
            <span class="badge text-bg-@StatusClass(t.Status)">@t.Status</span>
            @if (authed)
            {
                <form asp-action="Delete" asp-route-id="@t.Id" method="post" class="d-inline ms-2 position-relative" style="z-index:5"
                      onsubmit="return confirm('Delete @t.Name?');">
                    <button class="btn btn-sm btn-outline-danger">×</button>
                </form>
            }
        </div>
    }
</div>

@functions {
    static string StatusClass(TournamentStatus s) => s switch
    {
        TournamentStatus.Draft => "secondary",
        TournamentStatus.GroupStage => "warning",
        TournamentStatus.KnockoutStage => "danger",
        TournamentStatus.Finished => "success",
        _ => "secondary"
    };
}
