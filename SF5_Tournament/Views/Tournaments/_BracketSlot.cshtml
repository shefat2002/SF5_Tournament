@model Match?
@{
    var label = ViewData["Label"]?.ToString() ?? "";
    var m = Model;
}

<div class="card bg-dark border-secondary text-light bracket-slot" style="min-width:210px">
    <div class="card-header py-1 small text-secondary text-uppercase">@label</div>
    <div class="card-body p-2">
        @if (m is null)
        {
            <div class="text-secondary text-center py-3 small">Awaiting result</div>
        }
        else
        {
            <div class="d-flex justify-content-between align-items-center">
                <span class="text-truncate @(m.WinnerId == m.Player1Id ? "fw-bold text-warning" : "")">@m.Player1?.Name</span>
                <span class="badge text-bg-dark border border-secondary">@SlotScore(m.Player1Score)</span>
            </div>
            <div class="d-flex justify-content-between align-items-center mt-1">
                <span class="text-truncate @(m.WinnerId == m.Player2Id ? "fw-bold text-warning" : "")">@m.Player2?.Name</span>
                <span class="badge text-bg-dark border border-secondary">@SlotScore(m.Player2Score)</span>
            </div>
            @if (!m.IsCompleted && m.Player1 is not null && m.Player2 is not null && User.Identity?.IsAuthenticated == true)
            {
                <button type="button" class="btn btn-sm btn-outline-warning w-100 mt-2"
                        onclick="openScore('@m.Id', @Json.Serialize(m.Player1?.Name), @Json.Serialize(m.Player2?.Name))">
                    enter
                </button>
            }
        }
    </div>
</div>

@functions {
    static string SlotScore(int? s) => s is null ? "-" : s.Value.ToString();
}
