@model LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<div class="row justify-content-center">
    <div class="col-12 col-sm-8 col-md-5 col-lg-4">
        <div class="card bg-dark border-secondary text-light shadow">
            <div class="card-body p-3 p-md-4">
                <h2 class="card-title text-center mb-1 fw-bold">SF5 Tournament</h2>
                <p class="text-center text-secondary small mb-4">Admin Login</p>

                <form asp-action="Login" asp-controller="Auth" method="post">
                    <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]"/>
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

                    <div class="mb-3">
                        <label asp-for="Username" class="form-label"></label>
                        <input asp-for="Username" class="form-control" autofocus/>
                        <span asp-validation-for="Username" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label"></label>
                        <input asp-for="Password" class="form-control"/>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-warning w-100 fw-bold">Sign In</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}
