@{
    ViewData["Title"] = "Home";
    var authed = User.Identity?.IsAuthenticated == true;
}

<div class="text-center py-4">
    <h1 class="display-5 fw-bold">SF5 Tournament</h1>
    <p class="text-secondary">Street Fighter 5 local tournament management — round robin groups, live scores, Top 4 bracket.</p>

    <div class="d-flex justify-content-center gap-2 flex-wrap mt-4">
        @if (authed)
        {
            <a class="btn btn-warning fw-bold" asp-controller="Tournaments" asp-action="Index">Tournaments</a>
            <a class="btn btn-outline-light" asp-controller="Players" asp-action="Index">Players</a>
        }
        else
        {
            <a class="btn btn-warning fw-bold" asp-controller="Auth" asp-action="Login">Admin Login</a>
        }
    </div>
</div>
