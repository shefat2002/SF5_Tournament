@model IEnumerable<Player>
@{
    ViewData["Title"] = "Players";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Players</h2>
    <a class="btn btn-warning fw-bold" asp-action="Create">+ Add Player</a>
</div>

@if (TempData["Error"] is string err)
{
    <div class="alert alert-danger">@err</div>
}

<div class="table-responsive">
    <table class="table table-dark table-striped align-middle">
        <thead>
        <tr>
            <th>Name</th>
            <th>Main Character</th>
            <th class="text-end">Actions</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var p in Model)
        {
            <tr>
                <td class="fw-semibold">@p.Name</td>
                <td>@p.MainCharacter</td>
                <td class="text-end text-nowrap">
                    <a class="btn btn-sm btn-outline-light me-1" asp-action="Edit" asp-route-id="@p.Id">Edit</a>
                    <form asp-action="Delete" asp-route-id="@p.Id" method="post" class="d-inline"
                          onsubmit="return confirm('Delete @p.Name?');">
                        <button class="btn btn-sm btn-outline-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
